# .env.example - Environment variables for Robot Orchestrator
# Copy to .env and adjust as needed.
# DO NOT commit .env to version control.

# -----------------------------------------------------------------------
# CLI tool paths
# -----------------------------------------------------------------------

# Codex CLI command (ChatGPT Plus / Codex subscription required)
# Install: https://github.com/openai/codex
CODEX_CMD=codex

# Codex model to use for plan/audit.
# Leave unset to use the model from ~/.codex/config.toml (recommended).
# Example overrides: gpt-5.4, o3
# CODEX_MODEL=

# Claude Code CLI command (Claude Max subscription required)
# Install: npm install -g @anthropic-ai/claude-code
CLAUDE_CMD=claude

# -----------------------------------------------------------------------
# Orchestrator behavior
# -----------------------------------------------------------------------

# Set to "true" to skip real CLI calls and use mock responses
# Useful for testing the state machine without spending tokens
MOCK_MODE=false

# Maximum retry attempts when Codex returns REWORK verdict (default: 2)
# MAX_RETRIES=2

# -----------------------------------------------------------------------
# Timeouts (seconds)
# -----------------------------------------------------------------------

# Codex plan/audit timeout
# CODEX_TIMEOUT=300

# Claude Code execution timeout
# CLAUDE_TIMEOUT=600

# colcon build timeout
# BUILD_TIMEOUT=300

# colcon test timeout
# TEST_TIMEOUT=300

# Simulation smoke test timeout
# SIM_TIMEOUT=120

# -----------------------------------------------------------------------
# OpenClaw / Discord (optional)
# -----------------------------------------------------------------------

# Option A: Discord Webhook URL (easiest — send-only, no bot setup needed)
# Create at: Server Settings > Integrations > Webhooks > New Webhook > Copy URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<id>/<token>

# Option B: Discord Bot Token + Channel ID (alternative)
# Create bot at: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your-bot-token-here
# DISCORD_CHANNEL_ID=your-channel-id-here

# -----------------------------------------------------------------------
# ROS2 environment (set by sourcing ROS2 setup.bash)
# -----------------------------------------------------------------------
# These are normally set by: source /opt/ros/humble/setup.bash
# ROS_DISTRO=humble
# ROS_VERSION=2
